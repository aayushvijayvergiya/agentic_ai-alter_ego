# Required environment variables
OPENAI_API_KEY=your_openai_api_key_here

# Optional - for push notifications
PUSHOVER_USER=your_pushover_user_key
PUSHOVER_TOKEN=your_pushover_app_token

# Optional - GitHub profile integration
GITHUB_USERNAME=aayushvijayvergiya
GITHUB_TOKEN=your_github_personal_access_token  # Increases rate limit from 60 to 5000 req/hr
GITHUB_CACHE_DURATION=3600  # Cache TTL in seconds (default: 3600)

# Optional - portfolio website scraping
PORTFOLIO_URL=https://your-portfolio.com
PORTFOLIO_CACHE_DURATION=3600

# Optional - HTTP settings
REQUEST_TIMEOUT=10
